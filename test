        if not _G.HogyokuFinished then
            -- Only auto-finish if we can positively confirm quest is done and GUI is loaded
            local needsQuest = checkHogyokuRequirement()
            if needsQuest then
                _G.DoingHogyokuQuest = true
            elseif _G.HogyokuStep > 1 then
                -- If we've already started, don't stop just because UI is nil/closed
                 _G.DoingHogyokuQuest = true
            end
        end

        if not _G.DoingHogyokuQuest then
            _G.TargetHogyoku = nil
            continue
        end

        local stepData = HogyokuSteps[_G.HogyokuStep]
        if not stepData then
            _G.DoingHogyokuQuest = false
            _G.HogyokuFinished = true
            _G.TargetHogyoku = nil
            Window:Notify({Title = "Hogyoku Quest", Desc = "✅ Quest Complete!", Time = 5})
