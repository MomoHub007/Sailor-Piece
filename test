local function findQuestTarget(targetName, islandName)
    -- Check common folders
    local target = workspace:FindFirstChild(targetName)
        or (workspace:FindFirstChild("NPCs") and workspace.NPCs:FindFirstChild(targetName))
        or (workspace:FindFirstChild("ServiceNPCs") and workspace.ServiceNPCs:FindFirstChild(targetName))
    
    if target then return target end

    -- Check island folders
    if islandName then
        local island = workspace:FindFirstChild(islandName)
        if island then
            target = island:FindFirstChild(targetName)
            if target then return target end
        end
        -- Try with "Island" suffix
        local island2 = workspace:FindFirstChild(islandName .. "Island")
        if island2 then
            target = island2:FindFirstChild(targetName)
            if target then return target end
        end
    end
    
    -- Final desperate search
    for _, folder in pairs(workspace:GetChildren()) do
        if folder:IsA("Folder") or folder:IsA("Model") then
            local found = folder:FindFirstChild(targetName)
            if found then return found end
        end
    end
    
    return nil
end

local function getIslandFolder(islandName)
    if not islandName then return nil end
    return workspace:FindFirstChild(islandName) 
        or workspace:FindFirstChild(islandName .. "Island")
        or workspace:FindFirstChild(islandName .. "Station")
end

