        end

        local islandFolder = getIslandFolder(stepData.Island)
        local needTeleport = true
        if islandFolder then
            local anyPart = islandFolder:FindFirstChildWhichIsA("BasePart", true)
            if anyPart and (root.Position - anyPart.Position).Magnitude < 3000 then
                needTeleport = false
            end
        end

        if needTeleport then
            _G.TargetHogyoku = nil
            pcall(function() RS:WaitForChild("Remotes"):WaitForChild("TeleportToPortal"):FireServer(stepData.Prefix) end)
            Window:Notify({Title = "Hogyoku Quest", Desc = "🚀 Step " .. _G.HogyokuStep .. ": → " .. stepData.Island, Time = 3})
            task.wait(3)
            continue
        end

        local targetObj = findQuestTarget(stepData.TargetName, stepData.Island)

        if not targetObj then
            -- Skip if not found, but it might just be map loading
            if not needTeleport then
                _G.HogyokuStep = _G.HogyokuStep + 1
            end
            continue
        end

        local targetPos = targetObj:IsA("Model")
            and (targetObj.PrimaryPart and targetObj.PrimaryPart.Position or targetObj:GetPivot().Position)
            or targetObj.Position
        targetPos = targetPos + Vector3.new(0, 3, 0)

        _G.TargetHogyoku = targetObj

        local oldBv = root:FindFirstChild("MomoWarpBV") or root:FindFirstChild("MomoBV")
        if oldBv then oldBv:Destroy() end

        hum.PlatformStand = false
        root.Anchored = false

        if root then
            SafeBypassWarp(targetPos, targetPos, 2)
        end

        local dist = (root.Position - targetPos).Magnitude
        if MoMoConfig.AutoHogyoku and _G.DoingHogyokuQuest and root and dist < 20 then
            
            local currentStep = _G.HogyokuStep
            local maxRetries = 20
            local retries = 0

            repeat
                root.Anchored = false
                root.Velocity = Vector3.new(0, 0, 0)
                if hum then hum.PlatformStand = false end
                for _, part in pairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = true end
                end
                
                if stepData.Type == "NPC" then
                    pcall(function() RS.RemoteEvents.QuestAccept:FireServer(stepData.TargetName) end)
                    local prompt = targetObj:FindFirstChildWhichIsA("ProximityPrompt", true)
                    if prompt then fireproximityprompt(prompt) end
                elseif stepData.Type == "Fragment" then
                    local prompt = targetObj:FindFirstChildWhichIsA("ProximityPrompt", true)
                    if prompt then
                        fireproximityprompt(prompt)
                    else
                        if targetObj:IsA("BasePart") then
                            firetouchinterest(root, targetObj, 0)
                            firetouchinterest(root, targetObj, 1)
                        end
                        for _, part in pairs(targetObj:GetDescendants()) do
                            if part:IsA("BasePart") then
                                firetouchinterest(root, part, 0)
                                firetouchinterest(root, part, 1)
                            end
                        end
                    end
                end

                task.wait(0.5)
                retries = retries + 1
                
                -- Check if target still exists to break the loop (useful for items that disappear when collected)
                if stepData.Type == "Fragment" and not targetObj.Parent then
                    break
                end
            until not MoMoConfig.AutoHogyoku or not _G.DoingHogyokuQuest or retries >= maxRetries

            _G.HogyokuStep = _G.HogyokuStep + 1
            Window:Notify({Title = "Hogyoku Quest", Desc = "✅ Step " .. (_G.HogyokuStep - 1) .. " Done!", Time = 2})
            task.wait(1)
        end

        _G.TargetHogyoku = nil
    end
end)

